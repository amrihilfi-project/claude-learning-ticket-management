generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth models ───────────────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  role          Role      @default(AGENT)
  isActive      Boolean   @default(true)
  deletedAt     DateTime?
  sessions      Session[]
  accounts      Account[]
  tickets       Ticket[]  @relation("AssignedTickets")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ─── App models ───────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  AGENT
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketCategory {
  GENERAL_QUESTION
  TECHNICAL_ISSUE
  REFUND_REQUEST
}

model Ticket {
  id             String          @id @default(cuid())
  subject        String
  body           String
  studentEmail   String
  status         TicketStatus    @default(OPEN)
  category       TicketCategory?
  summary        String?
  suggestedReply String?
  assigneeId     String?
  assignee       User?           @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)
  resolvedAt     DateTime?
  emailMessageId String?
  messages       TicketMessage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("ticket")
}

model TicketMessage {
  id             String   @id @default(cuid())
  ticketId       String
  ticket         Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body           String
  fromStudent    Boolean
  emailMessageId String?
  createdAt      DateTime @default(now())

  @@map("ticket_message")
}
